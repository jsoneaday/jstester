{
  "name": "jstester",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "scripts": {
    "bootstrap": "npm install",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "test": "vitest",
    "typecheck": "tsc -p packages/lib/tsconfig.json --noEmit",
    "lib:build": "npm --workspace ./packages/lib run build",
    "client:dev": "npm --workspace ./packages/client run dev",
    "client:build": "npm --workspace ./packages/client run build",
    "client:test": "npm --workspace ./packages/client run test"
  },
  "devDependencies": {
    "jsdom": "^29.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
